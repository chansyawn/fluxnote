{
  "name": "fluxnote",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "flux": ".vite/cli/flux-cli.mjs"
  },
  "type": "module",
  "main": ".vite/build/main.cjs",
  "imports": {
    "#global.css": "./src/renderer/global.css"
  },
  "scripts": {
    "cli:build": "vp build -c vite.cli.config.ts",
    "db:generate": "drizzle-kit generate",
    "dev": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "flux": "vp build -c vite.cli.config.ts && ./src/cli/flux",
    "lingui": "lingui",
    "lingui:extract": "lingui extract --overwrite --clean",
    "lingui:compile": "lingui compile --strict"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@lexical/clipboard": "^0.43.0",
    "@lexical/code-core": "^0.43.0",
    "@lexical/code-shiki": "^0.43.0",
    "@lexical/extension": "^0.43.0",
    "@lexical/history": "^0.43.0",
    "@lexical/link": "^0.43.0",
    "@lexical/list": "^0.43.0",
    "@lexical/markdown": "^0.43.0",
    "@lexical/react": "^0.43.0",
    "@lexical/rich-text": "^0.43.0",
    "@lexical/table": "^0.43.0",
    "@lingui/core": "6.0.0-next.3",
    "@lingui/detect-locale": "6.0.0-next.3",
    "@lingui/react": "6.0.0-next.3",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-virtual": "^3.13.24",
    "better-sqlite3": "^12.9.0",
    "cac": "^7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "electron-store": "^11.0.2",
    "lexical": "^0.43.0",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^10.1.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-forge/cli": "8.0.0-alpha.8",
    "@electron-forge/maker-zip": "8.0.0-alpha.8",
    "@electron-forge/plugin-auto-unpack-natives": "8.0.0-alpha.8",
    "@electron-forge/plugin-fuses": "8.0.0-alpha.8",
    "@electron-forge/plugin-vite": "8.0.0-alpha.8",
    "@electron-forge/shared-types": "8.0.0-alpha.8",
    "@electron/fuses": "2.1.1",
    "@lingui/babel-plugin-lingui-macro": "6.0.0-next.3",
    "@lingui/cli": "6.0.0-next.3",
    "@lingui/vite-plugin": "6.0.0-next.3",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "electron": "41.3.0",
    "typescript": "~5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "config": {
    "forge": "./forge.config.ts"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron"
    ]
  },
  "productName": "fluxnote"
}
