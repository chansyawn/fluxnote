{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fluxnote",
  "version": "0.1.0",
  "identifier": "app.fluxnote",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/assets/**"]
      },
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: https:"
    },
    "windows": [
      {
        "title": "fluxnote",
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "maximizable": false,
        "acceptFirstMouse": true,
        "skipTaskbar": true,
        "width": 640,
        "minWidth": 320,
        "maxWidth": 640,
        "height": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["fluxnote"]
      }
    }
  }
}
